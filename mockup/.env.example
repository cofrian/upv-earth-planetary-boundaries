POSTGRES_USER=upvearth
POSTGRES_PASSWORD=upvearth
POSTGRES_DB=upvearth

APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=["*"]

MAX_UPLOAD_SIZE_MB=30
UPLOAD_DIR=/app/data/uploads

EMBEDDINGS_MODEL_NAME=sentence-transformers/allenai-specter
# Alternativas: sentence-transformers/all-MiniLM-L6-v2 (256 tokens, 384 dim, ligero, fallback)
#               allenai/specter2_base                  (requiere `pip install adapters`)
PB_REFERENCE_CSV=/app/corpus_PB/data/pb_reference.csv
PB_TOP_K=3

LLM_ENABLED=true
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL_NAME=qwen2.5:14b
LLM_TEMPERATURE=0.0

# Chatbot RAG (UPV-EARTH) — cliente LLM compatible con OpenAI Chat Completions.
# Apuntar a un servidor local: vLLM (`vllm serve`) o llama-cpp-python (`python -m llama_cpp.server`).
# Si LLM_ENABLED=false, el chatbot se muestra como "no disponible" y el resto sigue operativo.
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=qwen3-8b-instruct
LLM_API_KEY=local-key
LLM_REQUEST_TIMEOUT=120
LLM_MAX_TOKENS=512
CHAT_TEMPERATURE=0.2

NEXT_PUBLIC_API_BASE_URL=/api/v1
API_BASE_URL_INTERNAL=http://127.0.0.1:8000/api/v1
